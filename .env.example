# Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# Default agent to use: claude | gemini | codex
DEFAULT_AGENT=claude

# Comma-separated Telegram user IDs allowed to use the bot (leave empty to allow all)
AUTHORIZED_USERS=

# Enable debug logging
DEBUG=false

# CLI executable paths (defaults assume they are in PATH)
CLAUDE_CLI_PATH=claude
GEMINI_CLI_PATH=gemini
CODEX_CLI_PATH=codex

# Model overrides per agent (optional — CLIs use their defaults if not set)
# Claude: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6
# Gemini: gemini-2.5-pro | gemini-2.5-flash | gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-pro
# Codex (OpenAI): o4-mini | o3 | o3-mini (leave empty to use CLI default)
CODEX_MODEL=

# Max characters per Telegram message before splitting
MAX_RESPONSE_LENGTH=4000

# Personalization — soul & memories
SOUL_PATH=./data/SOUL.md
MEMORY_INJECT=recent
MEMORY_INJECT_LIMIT=2000

# Conversational memory
# Number of user/assistant exchange pairs to keep in context (default: 10, 0 = disabled)
HISTORY_WINDOW=10
# Session expiration in hours (default: 0 = never expire, sessions persist indefinitely)
SESSION_TTL_HOURS=0

# ─── Memoria de largo plazo (LTM) ────────────────────────────────────────────
# Activa/desactiva la compactación automática de conversaciones en LTM (default: true)
LTM_ENABLED=true

# Tamaño máximo del archivo LTM en caracteres antes de re-resumir (default: 4000)
LTM_MAX_CHARS=4000

# Timeout del call de compactación en segundos (default: 30)
LTM_COMPACT_TIMEOUT_SECONDS=30

# Audio transcription (mlx-whisper — requires: pip install mlx-whisper)
WHISPER_MODEL=mlx-community/whisper-base-mlx
WHISPER_LANGUAGE=es
AUDIO_TEMP_DIR=/tmp/krakbot-audio
MAX_AUDIO_SIZE_MB=25

# ─── Auto-update desde GitHub ────────────────────────────────────────────────
# Repo en formato "owner/repo" (dejar vacío para deshabilitar el auto-update)
GITHUB_REPO=DiegoBoni/KrakBot

# Rama a monitorear (default: main)
GITHUB_BRANCH=main

# Intervalo entre chequeos en horas (default: 24, 0 = deshabilitado)
UPDATE_CHECK_INTERVAL_HOURS=24

# Chat ID al que enviar notificaciones (default: primer usuario en AUTHORIZED_USERS)
NOTIFY_CHAT_ID=

# Token de GitHub para repos privados (opcional para repos públicos)
GITHUB_TOKEN=

# Nombre de la app en pm2 para el restart (default: krakbot)
PM2_APP_NAME=krakbot

# ─── TTS (Text-to-Speech) ─────────────────────────────────────────────────────
# Motor TTS: auto | edge-tts | say (default: auto — usa edge-tts si está instalado)
TTS_ENGINE=auto

# Forzar una voz específica de edge-tts para todos los usuarios (sobreescribe la sesión)
# Ej: es-AR-TomasNeural | es-AR-ElenaNeural | en-US-JennyNeural
TTS_VOICE=

# Máximo de chars a convertir a audio (default: 4000)
TTS_MAX_CHARS=4000

# ─── Archivos adjuntos ────────────────────────────────────────────────────────
# Tamaño máximo de archivos adjuntos en MB (default: 20 — límite real de Telegram)
MAX_FILE_SIZE_MB=20

# ─── Custom Agents ────────────────────────────────────────────────────────────
# CLI usado por el Root Agent para routing automático (default: claude)
ROOT_AGENT_CLI=claude

# ─── Encriptación de sesiones y memorias ─────────────────────────────────────
# Clave secreta para encriptar datos en disco (sesiones, memorias) con AES-256-GCM
# Si no se configura, los datos se guardan en texto plano (comportamiento anterior)
# Generá una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── Seguridad del proceso hijo ───────────────────────────────────────────────
# Rate limiting por usuario — máximo de requests por ventana (0 = deshabilitado)
RATE_LIMIT_MAX=10
# Duración de la ventana de rate limiting en segundos
RATE_LIMIT_WINDOW_SECONDS=60
# Variables extra para pasar al proceso CLI hijo, separadas por coma
# Formato: KEY=VALUE para valor explícito, o solo KEY para heredar del env del bot
# Ejemplo: CHILD_ENV_EXTRA=MY_VAR=foo,OTHER_VAR
CHILD_ENV_EXTRA=
